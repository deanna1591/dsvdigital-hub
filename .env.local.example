# =====================================================
# Supabase — from your project: Settings → API
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# Site URL — needed for OAuth callbacks
# =====================================================
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: set to https://portal.dsvdigital.com in Vercel env vars

# =====================================================
# Google Sheets sync (service account)
# =====================================================
# Create a service account in Google Cloud Console, generate a JSON key,
# share the sheet with the service account email, then paste below:
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the entire private_key value here (with \n escapes intact).
# Or base64-encode the whole JSON key file and store it as one string.
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SHEET_ID=1Osf9xFYGlPJ0nyTzzK567oy3VjD1mrDcdxjthREt0Mo
